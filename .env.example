# .env.example — copy to .env.claude and source before starting Claude Code
# Usage: cp .env.example .env.claude && source .env.claude

# ── Safety ────────────────────────────────────────────────────────────────────

# Allow direct pushes to main/master (off by default — guards in guard-dangerous-bash.sh)
# Uncomment only on branches where you deliberately want this.
# ALLOW_PUSH_MAIN=1

# ── Scheduled tasks / /loop ───────────────────────────────────────────────────

# Disable the /loop task scheduler entirely.
# Set this in CI environments to prevent scheduled tasks from firing during
# automated runs. Without it, any scheduled tasks in the session will fire
# on their normal interval even inside a non-interactive pipeline.
# CLAUDE_CODE_DISABLE_CRON=1

# ── Cloud Routines (/schedule) ────────────────────────────────────────────────

# Cloud Routines require a claude.ai subscription login — NOT an API key.
# If any of the following are set, /schedule silently returns "Unknown command"
# with no error message. Minimum CLI version: v2.1.81.
#
# Variables that suppress /schedule:
#   ANTHROPIC_API_KEY
#   ANTHROPIC_AUTH_TOKEN
#   DISABLE_TELEMETRY
#   DO_NOT_TRACK
#   CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC
#
# If you need both API key access and Cloud Routines, use separate shell
# profiles: one with the API key set (for SDK work), one without (for CLI).

# ── Agent Teams ───────────────────────────────────────────────────────────────

# Agent Teams is already enabled via .claude/settings.json.
# No env var needed unless you want to disable it for a specific session:
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=0
